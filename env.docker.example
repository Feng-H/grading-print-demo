# ===== 必填：请修改后另存为 .env =====

# Postgres密码（compose会用这个建库，app也用这个连接）
POSTGRES_PASSWORD=请改成一个强密码

# NextAuth密钥：生产环境请改成随机长字符串
# 生成方法: openssl rand -base64 32
AUTH_SECRET=please-change-this-to-a-long-random-string-in-production

# ===== 可选：AI批改（不填走Mock模式）=====
SILICONFLOW_API_KEY=
SILICONFLOW_MODEL=Qwen/Qwen3.6-35B-A3B

# ===== 打印机配置（FRP映射后的地址）=====
# 例如OpenWrt通过FRP把内网9100端口映射到VPS的9100，这里就填localhost
PRINTER_HOST=localhost
PRINTER_PORT=9100
PRINTER_PROTOCOL=raw
PRINTER_TIMEOUT_MS=30000

# ===== WebDAV（扫描仪上传目录）=====
# WEBDAV_BASE_URL=http://your-webdav:8080
# WEBDAV_USER=
# WEBDAV_PASS=
# WEBDAV_WATCH_PATH=/scans/inbox
# WEBDAV_WEBHOOK_TOKEN=
WEBDAV_POLL_INTERVAL_MS=60000

# ===== 其他 =====
PRINT_JOB_NAME_PREFIX=SWP
