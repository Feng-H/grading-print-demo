# 数据库连接串 - Vercel Postgres创建后自动注入，本地开发可使用远程连接串或本地Postgres
DATABASE_URL="postgres://..."

# NextAuth密钥 - 随机生成，生产环境务必修改
AUTH_SECRET="please-change-this-to-a-random-secret-key-in-production"
NEXTAUTH_SECRET="please-change-this-to-a-random-secret-key-in-production"
NEXTAUTH_URL="http://localhost:3000"

# SiliconFlow API配置 - 从 https://siliconflow.cn/ 获取API Key
SILICONFLOW_API_KEY="sk-your-api-key-here"
# 文本批改模型
SILICONFLOW_MODEL="Qwen/Qwen3-27B-Instruct"
# 视觉识别模型（用于上传试卷OCR）
SILICONFLOW_VL_MODEL="Qwen/Qwen2.5-VL-72B-Instruct"

# === 自托管部署新增配置 ===

# 文件存储根目录（Docker部署挂盘到/data/storage）
STORAGE_ROOT="/data/storage"

# 是否启动内置队列调度器（Docker部署必须设为1，Vercel/serverless设为0）
RUN_QUEUE=1

# WebDAV扫描仪文件夹配置
WEBDAV_BASE_URL=""
WEBDAV_USER=""
WEBDAV_PASS=""
WEBDAV_WATCH_PATH="/scans/inbox"
WEBDAV_WEBHOOK_TOKEN=""
WEBDAV_POLL_INTERVAL_MS=60000

# 打印机配置（Linux无驱动通用方案）
# 要求打印机原生支持PDF Direct Print（企业级激光/IPP Everywhere打印机普遍支持）
PRINTER_HOST=""
PRINTER_PORT=9100
PRINTER_PROTOCOL="raw"   # raw(9100) | ipp(631)
PRINTER_TIMEOUT_MS=30000
PRINT_MAX_CONCURRENCY=1  # 串行打印避免乱页
PRINT_JOB_NAME_PREFIX="SWP"
