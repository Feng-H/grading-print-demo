# 数据库连接串 - Vercel Postgres创建后自动注入，本地开发可使用远程连接串或本地Postgres
DATABASE_URL="postgres://..."

# NextAuth密钥 - 随机生成，生产环境务必修改
AUTH_SECRET="please-change-this-to-a-random-secret-key-in-production"
NEXTAUTH_SECRET="please-change-this-to-a-random-secret-key-in-production"

# SiliconFlow API配置 - 从 https://siliconflow.cn/ 获取API Key
SILICONFLOW_API_KEY="sk-your-api-key-here"
# 文本批改模型
SILICONFLOW_MODEL="Qwen/Qwen3-27B-Instruct"
# 视觉识别模型（用于上传试卷OCR）
SILICONFLOW_VL_MODEL="Qwen/Qwen2.5-VL-72B-Instruct"
